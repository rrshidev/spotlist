# === Yandex Metrica ===
# Counter ID for analytics (optional). Get it from https://metrika.yandex.ru
NEXT_PUBLIC_YM_COUNTER_ID=

# === Domain ===
DOMAIN=yourdomain.ru

# === Database ===
POSTGRES_USER=spotlist
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=spotlist

# === Backend ===
SECRET_KEY=replace-with-a-random-64-char-string

# === Weather (OpenWeatherMap) ===
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# === Donate ===
# Phone number for donations (shown on /donate page)
NEXT_PUBLIC_DONATE_PHONE=+79532863360

# === Push notifications (VAPID) ===
# Generate keys: python -c "from cryptography.hazmat.primitives import serialization; from cryptography.hazmat.primitives.asymmetric import ec; import base64; key=ec.generate_private_key(ec.SECP256R1()); priv=key.private_bytes(serialization.Encoding.PEM,serialization.PrivateFormat.PKCS8,serialization.NoEncryption()).decode().strip(); pub=key.public_key().public_bytes(serialization.Encoding.X962,serialization.PublicFormat.UncompressedPoint); print('VAPID_PUBLIC_KEY='+base64.urlsafe_b64encode(pub).rstrip(b'=').decode()); print('VAPID_PRIVATE_KEY='+base64.b64encode(priv.encode()).decode())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:contact@spotlist.app
